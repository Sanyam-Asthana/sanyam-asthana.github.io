From 40758e6d2f1aef2c7891aff35805df7d4a7da54e Mon Sep 17 00:00:00 2001
From: Sanyam Asthana <sanyam.asthana@gmail.com>
Date: Sat, 21 Mar 2026 02:35:55 +0530
Subject: [PATCH 04/10] fix font rendering and hide terminal on narrow screens

---
 styles.css | 13 ++++++++++---
 1 file changed, 10 insertions(+), 3 deletions(-)

diff --git a/styles.css b/styles.css
index 4d1bb34..fdeeb8f 100644
--- a/styles.css
+++ b/styles.css
@@ -25,14 +25,14 @@
 
 @font-face { /* JetBrains Supremacy */
     font-family: 'JetBrainsMono Nerd Font';
-    src: url('fonts/JetBrainsMonoNerdFont-Regular.ttf') format('truetype');
+    src: url('JetBrainsMonoNerdFont-Regular.ttf') format('truetype');
     font-weight: normal;
     font-style: normal;
 }
 
 body {
     margin: 0; /* The body imposes some amount of margin by default, so we reset it to 0 */
-    font-family: JetBrainsMono Nerd Font; /* My favorite font, and now yours too, without questions */
+    font-family: 'JetBrainsMono Nerd Font'; /* My favorite font, and now yours too, without questions */
     color: var(--primary-text);
     height: 100vh; /* The body extends all the way down so the sidebar and main content fill all the page */
     display: flex; /* So we can tell main-content to take all the space */
@@ -323,6 +323,12 @@ a {
     height: 275px;
 }
 
+@media screen and (max-width: 768px) {
+    #terminal {
+        display: none;
+    }
+}
+
 #terminal-tab-bar {
     background-color: var(--header-bg-color);
     border-top: 1px solid var(--primary-border);
@@ -334,6 +340,7 @@ a {
 #terminal-content {
     background-color: var(--content-bg-color);
     padding: 10px;
+    outline: none;
 }
 
 .terminal-tab {
@@ -347,7 +354,7 @@ a {
 
 /* These few classes exist to support the toggleable functionality */
 .hidden {
-    display: none;
+    display: none !important;
 }
 
 .full-width {
-- 
